{
  "threat_model": {
    "name": "Credential Abuse Detection Model",
    "version": "1.0",
    "description": "Detect credential theft, abuse, and compromise using behavioral analytics",
    "risk_indicators": [
      {
        "id": "CA-RI-001",
        "name": "Brute Force Pattern",
        "type": "threshold",
        "data_source": "authentication",
        "conditions": {"outcome": "failure", "count_threshold": 10, "time_window_seconds": 300},
        "group_by": "source_address",
        "risk_score": 30
      },
      {
        "id": "CA-RI-002",
        "name": "Password Spray Pattern",
        "type": "threshold",
        "data_source": "authentication",
        "conditions": {"outcome": "failure", "unique_accounts_threshold": 5, "time_window_seconds": 600},
        "group_by": "source_address",
        "risk_score": 35
      },
      {
        "id": "CA-RI-003",
        "name": "Abnormal Authentication Location",
        "type": "geo_anomaly",
        "data_source": "authentication",
        "baseline": "user_login_locations",
        "risk_score": 25
      },
      {
        "id": "CA-RI-004",
        "name": "Credential Dumping Tool",
        "type": "signature",
        "data_source": "endpoint",
        "signatures": ["mimikatz", "procdump.*lsass", "sekurlsa", "comsvcs.*MiniDump"],
        "risk_score": 50
      },
      {
        "id": "CA-RI-005",
        "name": "Kerberoasting Activity",
        "type": "threshold",
        "data_source": "active_directory",
        "conditions": {"event_id": 4769, "encryption": ["0x17", "0x18"], "count_threshold": 3},
        "risk_score": 35
      },
      {
        "id": "CA-RI-006",
        "name": "Dormant Account Activation",
        "type": "behavioral_anomaly",
        "data_source": "authentication",
        "dormant_days": 90,
        "risk_score": 20
      }
    ],
    "risk_scoring": {
      "method": "cumulative_weighted",
      "thresholds": {"low": {"max": 25}, "medium": {"max": 50}, "high": {"max": 80}, "critical": {"min": 81}},
      "decay_rate_hours": 72
    },
    "response_actions": {
      "high": ["force_mfa", "create_case", "notify_iam_team"],
      "critical": ["disable_account", "revoke_sessions", "create_incident", "notify_ir_team"]
    }
  }
}
