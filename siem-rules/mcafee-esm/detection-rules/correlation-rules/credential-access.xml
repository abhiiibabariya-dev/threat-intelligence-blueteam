<?xml version="1.0" encoding="UTF-8"?>
<!-- McAfee ESM (Trellix) Correlation Rules - Credential Access -->
<!-- MITRE ATT&CK Tactic: TA0006 -->

<CorrelationRules>

  <CorrelationRule name="ESM-CA-001: Brute Force Attack" severity="80" enabled="true">
    <Description>Multiple authentication failures from single source - brute force indicator</Description>
    <MITREAttack>T1110.001</MITREAttack>
    <Filter operator="AND">
      <FilterCondition field="RULE_MSG" operator="CONTAINS" value="Authentication Failure"/>
      <FilterCondition field="SRC_IP" operator="NOT_EQUALS" value="127.0.0.1"/>
    </Filter>
    <Correlation>
      <TimeWindow value="300"/>
      <GroupBy field="SRC_IP"/>
      <Threshold count="10"/>
    </Correlation>
    <Actions>
      <Action type="createAlarm" assignee="SOC-L1" priority="HIGH"/>
      <Action type="addToWatchlist" name="Brute-Force-Sources"/>
    </Actions>
  </CorrelationRule>

  <CorrelationRule name="ESM-CA-002: Password Spray" severity="85" enabled="true">
    <Description>Single source targeting multiple accounts - password spray pattern</Description>
    <MITREAttack>T1110.003</MITREAttack>
    <Filter operator="AND">
      <FilterCondition field="RULE_MSG" operator="CONTAINS" value="Authentication Failure"/>
    </Filter>
    <Correlation>
      <TimeWindow value="600"/>
      <GroupBy field="SRC_IP"/>
      <UniqueValues field="DST_USER" minimum="5"/>
      <Threshold count="10"/>
    </Correlation>
    <Actions>
      <Action type="createAlarm" assignee="SOC-L2" priority="HIGH"/>
      <Action type="sendNotification" template="Password-Spray-Alert"/>
    </Actions>
  </CorrelationRule>

  <CorrelationRule name="ESM-CA-003: LSASS Memory Dump" severity="95" enabled="true">
    <Description>Process accessing LSASS memory for credential theft</Description>
    <MITREAttack>T1003.001</MITREAttack>
    <Filter operator="AND">
      <FilterCondition field="DST_PROCESS" operator="EQUALS" value="lsass.exe"/>
      <FilterCondition field="ACCESS_MASK" operator="IN" value="0x1010,0x1038,0x1fffff"/>
      <FilterCondition field="SRC_PROCESS" operator="NOT_IN" value="csrss.exe,svchost.exe,MsMpEng.exe"/>
    </Filter>
    <Correlation>
      <TimeWindow value="60"/>
      <Threshold count="1"/>
    </Correlation>
    <Actions>
      <Action type="createAlarm" assignee="SOC-L3" priority="CRITICAL"/>
      <Action type="executeScript" name="Isolate-Host"/>
    </Actions>
  </CorrelationRule>

  <CorrelationRule name="ESM-CA-004: Kerberoasting" severity="80" enabled="true">
    <Description>TGS ticket requests with RC4 encryption indicating Kerberoasting</Description>
    <MITREAttack>T1558.003</MITREAttack>
    <Filter operator="AND">
      <FilterCondition field="EVENT_ID" operator="EQUALS" value="4769"/>
      <FilterCondition field="ENCRYPTION_TYPE" operator="IN" value="0x17,0x18"/>
    </Filter>
    <Correlation>
      <TimeWindow value="300"/>
      <GroupBy field="SRC_USER"/>
      <Threshold count="5"/>
    </Correlation>
    <Actions>
      <Action type="createAlarm" assignee="SOC-L2" priority="HIGH"/>
    </Actions>
  </CorrelationRule>

  <CorrelationRule name="ESM-CA-005: DCSync Attack" severity="98" enabled="true">
    <Description>Directory replication from non-DC host - DCSync attack</Description>
    <MITREAttack>T1003.006</MITREAttack>
    <Filter operator="AND">
      <FilterCondition field="EVENT_ID" operator="EQUALS" value="4662"/>
      <FilterCondition field="PROPERTIES" operator="CONTAINS" value="1131f6aa-9c07-11d1-f79f-00c04fc2dcd2"/>
      <FilterCondition field="SRC_IP" operator="NOT_IN_WATCHLIST" value="Domain-Controllers"/>
    </Filter>
    <Correlation>
      <TimeWindow value="60"/>
      <Threshold count="1"/>
    </Correlation>
    <Actions>
      <Action type="createAlarm" assignee="IR-Team" priority="CRITICAL"/>
      <Action type="sendNotification" template="DCSync-Alert"/>
      <Action type="executeScript" name="Disable-Account"/>
    </Actions>
  </CorrelationRule>

</CorrelationRules>
