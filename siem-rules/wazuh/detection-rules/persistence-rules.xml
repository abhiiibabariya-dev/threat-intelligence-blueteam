<!-- Wazuh Detection Rules: Persistence -->
<!-- MITRE ATT&CK Tactic: TA0003 - Persistence -->
<!-- Rule IDs: 100120-100139 -->

<group name="persistence,mitre_ta0003,">

  <!-- T1547.001 - Registry Run Keys -->
  <rule id="100120" level="10">
    <if_sid>61600,61601</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\\\CurrentVersion\\\\Run|\\\\CurrentVersion\\\\RunOnce|\\\\CurrentVersion\\\\RunOnceEx</field>
    <description>Persistence: Registry Run key modified - $(win.eventdata.targetObject)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
    <group>registry_persistence,run_keys,</group>
  </rule>

  <!-- T1053.005 - Scheduled Task Creation -->
  <rule id="100121" level="10">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">4698</field>
    <description>Persistence: Scheduled task created - $(win.eventdata.taskName) by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
    <group>scheduled_task,</group>
  </rule>

  <!-- T1053.005 - Suspicious Scheduled Task via Command Line -->
  <rule id="100122" level="12">
    <if_sid>61601</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)schtasks\s+/create.*(/sc\s+(minute|hourly)|/ru\s+system|/tn\s+\\\\)</field>
    <description>Persistence: Suspicious scheduled task created via command line - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
    <group>scheduled_task,suspicious,</group>
  </rule>

  <!-- T1543.003 - Windows Service Creation -->
  <rule id="100123" level="10">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">7045</field>
    <description>Persistence: New service installed - $(win.eventdata.serviceName) ($(win.eventdata.imagePath))</description>
    <mitre>
      <id>T1543.003</id>
    </mitre>
    <group>new_service,</group>
  </rule>

  <!-- T1543.003 - Suspicious Service with cmd/powershell -->
  <rule id="100124" level="14">
    <if_sid>100123</if_sid>
    <field name="win.eventdata.imagePath" type="pcre2">(?i)cmd\.exe|powershell|pwsh|mshta|wscript|cscript|rundll32</field>
    <description>Persistence: Suspicious service created with scripting engine - $(win.eventdata.serviceName)</description>
    <mitre>
      <id>T1543.003</id>
    </mitre>
    <group>suspicious_service,critical,</group>
  </rule>

  <!-- T1546.003 - WMI Event Subscription -->
  <rule id="100125" level="12">
    <if_sid>61601</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)wmic.*\/namespace.*__EventFilter|__EventConsumer|__FilterToConsumerBinding|Register-WmiEvent</field>
    <description>Persistence: WMI event subscription created for persistence</description>
    <mitre>
      <id>T1546.003</id>
    </mitre>
    <group>wmi_persistence,</group>
  </rule>

  <!-- T1547.004 - Winlogon Helper DLL -->
  <rule id="100126" level="12">
    <if_sid>61600</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\\\Microsoft\\\\Windows NT\\\\CurrentVersion\\\\Winlogon\\\\(Shell|Userinit|Notify|Taskman)</field>
    <description>Persistence: Winlogon helper registry key modified - $(win.eventdata.targetObject)</description>
    <mitre>
      <id>T1547.004</id>
    </mitre>
    <group>winlogon_persistence,</group>
  </rule>

  <!-- T1136.001 - Local Account Creation -->
  <rule id="100127" level="10">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">4720</field>
    <description>Persistence: New local user account created - $(win.eventdata.targetUserName) by $(win.eventdata.subjectUserName)</description>
    <mitre>
      <id>T1136.001</id>
    </mitre>
    <group>account_creation,</group>
  </rule>

  <!-- T1098 - Account Added to Admin Group -->
  <rule id="100128" level="14">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">4732</field>
    <field name="win.eventdata.targetUserName" type="pcre2">(?i)administrators</field>
    <description>Persistence: Account $(win.eventdata.memberSid) added to Administrators group</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>admin_group_modification,critical,</group>
    <options>alert_by_email</options>
  </rule>

  <!-- T1546.001 - Change Default File Association -->
  <rule id="100129" level="10">
    <if_sid>61600</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\\\Classes\\\\.*\\\\shell\\\\open\\\\command</field>
    <description>Persistence: File association handler modified - $(win.eventdata.targetObject)</description>
    <mitre>
      <id>T1546.001</id>
    </mitre>
    <group>file_association_hijack,</group>
  </rule>

  <!-- Linux: Crontab Modification -->
  <rule id="100130" level="10">
    <if_sid>550,554</if_sid>
    <match type="pcre2">(?i)/var/spool/cron|/etc/cron|crontab</match>
    <description>Persistence: Crontab modification detected</description>
    <mitre>
      <id>T1053.003</id>
    </mitre>
    <group>linux_persistence,crontab,</group>
  </rule>

  <!-- Linux: SSH Authorized Keys Modified -->
  <rule id="100131" level="12">
    <if_sid>550,554</if_sid>
    <match type="pcre2">\.ssh/authorized_keys</match>
    <description>Persistence: SSH authorized_keys file modified</description>
    <mitre>
      <id>T1098.004</id>
    </mitre>
    <group>linux_persistence,ssh_keys,</group>
  </rule>

</group>
