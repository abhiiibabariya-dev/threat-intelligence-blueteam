<!-- Wazuh Detection Rules: Credential Access -->
<!-- MITRE ATT&CK Tactic: TA0006 - Credential Access -->
<!-- Rule IDs: 100100-100119 -->

<group name="credential_access,mitre_ta0006,">

  <!-- T1110.001 - Brute Force: Password Guessing -->
  <rule id="100100" level="10" frequency="8" timeframe="120">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip/>
    <description>Credential Access: Brute force attack detected - $(srcip) failed authentication 8+ times in 2 minutes</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,brute_force,pci_dss_10.2.4,pci_dss_11.4,gpg13_7.1,</group>
  </rule>

  <!-- T1110.003 - Password Spraying -->
  <rule id="100101" level="12" frequency="5" timeframe="300">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip/>
    <different_user/>
    <description>Credential Access: Password spray attack - $(srcip) targeting multiple accounts</description>
    <mitre>
      <id>T1110.003</id>
    </mitre>
    <group>authentication_failures,password_spray,pci_dss_10.2.4,</group>
  </rule>

  <!-- T1003.001 - LSASS Memory Dumping -->
  <rule id="100102" level="15">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\\\lsass\.dmp|\\\\lsass\.zip|procdump.*lsass</field>
    <description>Credential Access: LSASS memory dump detected - possible credential theft</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_dumping,lsass,critical,</group>
    <options>alert_by_email</options>
  </rule>

  <!-- T1003.001 - LSASS Access via Sysmon Event 10 -->
  <rule id="100103" level="14">
    <if_sid>61650</if_sid>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe$</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">0x1010|0x1038|0x1fffff</field>
    <description>Credential Access: Suspicious process accessing LSASS memory ($(win.eventdata.sourceImage))</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_dumping,lsass,sysmon_event10,</group>
  </rule>

  <!-- T1558.003 - Kerberoasting -->
  <rule id="100104" level="12">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">4769</field>
    <field name="win.eventdata.ticketEncryptionType" type="pcre2">0x17|0x18</field>
    <field name="win.eventdata.ticketOptions" type="pcre2">0x40810000</field>
    <description>Credential Access: Potential Kerberoasting - RC4 TGS ticket requested for $(win.eventdata.serviceName)</description>
    <mitre>
      <id>T1558.003</id>
    </mitre>
    <group>kerberoasting,active_directory,</group>
  </rule>

  <!-- T1003.006 - DCSync Attack -->
  <rule id="100105" level="15">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">4662</field>
    <field name="win.eventdata.properties" type="pcre2">1131f6aa-9c07-11d1-f79f-00c04fc2dcd2|1131f6ad-9c07-11d1-f79f-00c04fc2dcd2|89e95b76-444d-4c62-991a-0facbeda640c</field>
    <description>Credential Access: DCSync attack detected - $(win.eventdata.subjectUserName) replicating directory</description>
    <mitre>
      <id>T1003.006</id>
    </mitre>
    <group>dcsync,active_directory,critical,</group>
    <options>alert_by_email</options>
  </rule>

  <!-- T1555.003 - Credentials from Web Browsers -->
  <rule id="100106" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)Login Data|logins\.json|cookies\.sqlite|key[34]\.db|signons\.sqlite</field>
    <description>Credential Access: Browser credential store accessed by $(win.eventdata.image)</description>
    <mitre>
      <id>T1555.003</id>
    </mitre>
    <group>browser_credential_theft,</group>
  </rule>

  <!-- T1552.001 - Credentials in Files -->
  <rule id="100107" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\\\unattend\.xml|\\\\sysprep\.inf|\\\\web\.config|\\\\\.aws\\\\credentials|\\\\\.git-credentials</field>
    <description>Credential Access: Sensitive credential file accessed - $(win.eventdata.targetFilename)</description>
    <mitre>
      <id>T1552.001</id>
    </mitre>
    <group>credential_files,</group>
  </rule>

  <!-- T1003.004 - LSA Secrets -->
  <rule id="100108" level="14">
    <if_sid>61601</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)reg\s+save\s+hklm\\\\sam|reg\s+save\s+hklm\\\\security|reg\s+save\s+hklm\\\\system|secretsdump|lsadump</field>
    <description>Credential Access: LSA secrets extraction attempt via $(win.eventdata.image)</description>
    <mitre>
      <id>T1003.004</id>
    </mitre>
    <group>lsa_secrets,credential_dumping,</group>
  </rule>

  <!-- T1110.004 - Credential Stuffing -->
  <rule id="100109" level="11" frequency="20" timeframe="600">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip/>
    <different_user/>
    <description>Credential Access: Credential stuffing attack - $(srcip) attempting many different accounts rapidly</description>
    <mitre>
      <id>T1110.004</id>
    </mitre>
    <group>credential_stuffing,authentication_failures,</group>
  </rule>

  <!-- Linux: SSH Brute Force -->
  <rule id="100110" level="10" frequency="6" timeframe="120">
    <if_matched_sid>5716</if_matched_sid>
    <same_source_ip/>
    <description>Credential Access: SSH brute force from $(srcip) - 6+ failed attempts in 2 minutes</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>ssh_brute_force,linux,pci_dss_10.2.4,</group>
  </rule>

  <!-- T1557.001 - LLMNR/NBT-NS Poisoning (Responder) -->
  <rule id="100111" level="12">
    <if_sid>61601</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)responder|inveigh|nbns.*spoof|llmnr.*poison</field>
    <description>Credential Access: LLMNR/NBT-NS poisoning tool detected - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1557.001</id>
    </mitre>
    <group>network_poisoning,credential_theft,</group>
  </rule>

</group>
