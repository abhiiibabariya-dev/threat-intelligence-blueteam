<!-- Wazuh Detection Rules: Initial Access -->
<!-- MITRE ATT&CK Tactic: TA0001 - Initial Access -->
<!-- Rule IDs: 100230-100244 -->

<group name="initial_access,mitre_ta0001,">

  <!-- T1566.001 - Spearphishing Attachment (Office spawning child) -->
  <rule id="100230" level="14">
    <if_sid>61601</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(winword|excel|powerpnt|outlook|onenote)\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(cmd|powershell|pwsh|wscript|cscript|mshta|certutil|rundll32|regsvr32)\.exe$</field>
    <description>Initial Access: Office application spawned suspicious process - possible phishing payload</description>
    <mitre>
      <id>T1566.001</id>
    </mitre>
    <group>phishing,office_macro,critical,</group>
    <options>alert_by_email</options>
  </rule>

  <!-- T1566.001 - Macro Enabled Document Created -->
  <rule id="100231" level="8">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\.(docm|xlsm|pptm|dotm|xltm|xlam|ppam|sldm)$</field>
    <description>Initial Access: Macro-enabled document created - $(win.eventdata.targetFilename)</description>
    <mitre>
      <id>T1566.001</id>
    </mitre>
    <group>phishing,macro_document,</group>
  </rule>

  <!-- T1566.002 - Spearphishing Link (browser spawning suspicious process) -->
  <rule id="100232" level="12">
    <if_sid>61601</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(chrome|msedge|firefox|iexplore|brave|opera)\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(cmd|powershell|pwsh|mshta|wscript|cscript)\.exe$</field>
    <description>Initial Access: Browser spawned suspicious process - possible drive-by or phishing link</description>
    <mitre>
      <id>T1566.002</id>
    </mitre>
    <group>phishing_link,browser_exploit,</group>
  </rule>

  <!-- T1078.001 - Valid Accounts: Default Accounts -->
  <rule id="100233" level="12">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">4624</field>
    <field name="win.eventdata.targetUserName" type="pcre2">(?i)^(administrator|admin|guest|defaultaccount|defaultuser)$</field>
    <field name="win.eventdata.logonType" type="pcre2">3|10</field>
    <description>Initial Access: Remote login with default/built-in account $(win.eventdata.targetUserName)</description>
    <mitre>
      <id>T1078.001</id>
    </mitre>
    <group>default_account,remote_login,</group>
  </rule>

  <!-- T1190 - Exploit Public-Facing Application (IIS/Apache Errors) -->
  <rule id="100234" level="10" frequency="10" timeframe="60">
    <if_matched_sid>31101,31108</if_matched_sid>
    <same_source_ip/>
    <description>Initial Access: Web application exploit attempt - high rate of errors from $(srcip)</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>web_exploit,web_attack,</group>
  </rule>

  <!-- T1133 - External Remote Services (VPN/RDP from new location) -->
  <rule id="100235" level="8">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">4624</field>
    <field name="win.eventdata.logonType">10</field>
    <description>Initial Access: Remote Desktop login from $(win.eventdata.ipAddress) as $(win.eventdata.targetUserName)</description>
    <mitre>
      <id>T1133</id>
    </mitre>
    <group>external_remote_services,rdp,</group>
  </rule>

  <!-- T1199 - Trusted Relationship (Service Account Login) -->
  <rule id="100236" level="10">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">4624</field>
    <field name="win.eventdata.targetUserName" type="pcre2">(?i)(svc_|service_|sa_|app_)</field>
    <field name="win.eventdata.logonType" type="pcre2">3|10</field>
    <description>Initial Access: Service account $(win.eventdata.targetUserName) used for interactive logon from $(win.eventdata.ipAddress)</description>
    <mitre>
      <id>T1199</id>
    </mitre>
    <group>service_account_abuse,</group>
  </rule>

</group>
