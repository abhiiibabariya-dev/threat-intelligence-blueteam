<?xml version="1.0" encoding="UTF-8"?>
<!--
  ArcSight ESM Active Channel Definitions
  Description: Real-time monitoring channels for SOC operations
  Author: Blue Team
-->
<ActiveChannels xmlns="http://www.arcsight.com/esm/channels">

  <Channel id="channel-critical-alerts" enabled="true">
    <Name>Critical Security Alerts</Name>
    <Description>Real-time view of all critical and high severity security events</Description>
    <Filter>
      <Condition field="agentSeverity" operator="greaterThanOrEquals" value="8"/>
    </Filter>
    <DisplayFields>
      <Field>endTime</Field>
      <Field>name</Field>
      <Field>agentSeverity</Field>
      <Field>sourceAddress</Field>
      <Field>destinationAddress</Field>
      <Field>sourceUserName</Field>
      <Field>categoryBehavior</Field>
      <Field>categoryDeviceGroup</Field>
    </DisplayFields>
    <RefreshInterval unit="seconds">10</RefreshInterval>
    <MaxRows>1000</MaxRows>
  </Channel>

  <Channel id="channel-auth-events" enabled="true">
    <Name>Authentication Events Monitor</Name>
    <Description>Real-time authentication activity including failures and successes</Description>
    <Filter>
      <Condition field="categoryBehavior" operator="equals" value="/Authentication/Verify"/>
    </Filter>
    <DisplayFields>
      <Field>endTime</Field>
      <Field>sourceAddress</Field>
      <Field>destinationAddress</Field>
      <Field>sourceUserName</Field>
      <Field>targetUserName</Field>
      <Field>categoryOutcome</Field>
      <Field>deviceEventClassId</Field>
    </DisplayFields>
    <RefreshInterval unit="seconds">15</RefreshInterval>
  </Channel>

  <Channel id="channel-network-anomalies" enabled="true">
    <Name>Network Anomaly Monitor</Name>
    <Description>Real-time view of network anomalies and suspicious traffic</Description>
    <Filter>
      <Or>
        <Condition field="categoryDeviceGroup" operator="equals" value="/IDS"/>
        <Condition field="categoryDeviceGroup" operator="equals" value="/Firewall"/>
        <And>
          <Condition field="bytesOut" operator="greaterThan" value="52428800"/>
          <Condition field="destinationAddress" operator="notInSubnet" value="10.0.0.0/8"/>
        </And>
      </Or>
    </Filter>
    <DisplayFields>
      <Field>endTime</Field>
      <Field>name</Field>
      <Field>sourceAddress</Field>
      <Field>destinationAddress</Field>
      <Field>destinationPort</Field>
      <Field>bytesOut</Field>
      <Field>bytesIn</Field>
      <Field>agentSeverity</Field>
    </DisplayFields>
    <RefreshInterval unit="seconds">15</RefreshInterval>
  </Channel>

  <Channel id="channel-correlation-events" enabled="true">
    <Name>Correlation Events</Name>
    <Description>All events generated by ESM correlation rules</Description>
    <Filter>
      <Condition field="type" operator="equals" value="Correlation"/>
    </Filter>
    <DisplayFields>
      <Field>endTime</Field>
      <Field>name</Field>
      <Field>agentSeverity</Field>
      <Field>sourceAddress</Field>
      <Field>destinationAddress</Field>
      <Field>sourceUserName</Field>
      <Field>deviceCustomString6</Field>
    </DisplayFields>
    <RefreshInterval unit="seconds">10</RefreshInterval>
  </Channel>

</ActiveChannels>
